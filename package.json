{
  "name": "hono-drizzle-api-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production-ready REST API scaffolding with Bun, Hono, Drizzle ORM, and PostgreSQL.",
  "scripts": {
    "dev": "bun run --watch cmd/api/main.ts",
    "start": "bun run cmd/api/main.ts",
    "build": "bun build cmd/api/main.ts --outdir dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seeds/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "queue:worker": "bun run cmd/worker/main.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "hono-rate-limiter": "^0.5.3",
    "ioredis": "^5.11.1",
    "pg-boss": "^12.25.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
