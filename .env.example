# Example environment variables required by the API runtime and database tooling.
APP_NAME=codebase-hono

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Queue (pg-boss)
# QUEUE_DATABASE_URL=postgresql://user:password@localhost:5432/dbname  # defaults to DATABASE_URL
# QUEUE_ENABLED=true

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-random-secret
